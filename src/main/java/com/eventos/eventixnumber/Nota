package com.eventos.eventix.controller;

import com.eventos.eventix.model.EventosModel;
import com.eventos.eventix.service.EventosService;
import jakarta.validation.Valid;
import org.springframework.http.*;
import org.springframework.web.bind.annotation.*;
import java.util.List;

@RestController
@RequestMapping("/eventos")
public class EventosController {

    private final EventosService svc;

    public EventosController(EventosService svc) {
        this.svc = svc;
    }

    // REGISTRAR
    @PostMapping
    public ResponseEntity<EventosModel> registrar(@Valid @RequestBody EventosModel r) {
        return ResponseEntity.status(HttpStatus.CREATED).body(svc.guardar(r));
    }

    // LISTAR TODOS
    @GetMapping
    public ResponseEntity<List<EventosModel>> listarTodos() {
        return ResponseEntity.ok(svc.listarTodos());
    }

    // BUSCAR POR NOMBRE
    @GetMapping("/nombre/{nombre}")
    public ResponseEntity<EventosModel> buscarPorNombre(@PathVariable String nombre) {
        return ResponseEntity.ok(svc.buscarPorNombre(nombre));
    }

    // BUSCAR POR TIPO
    @GetMapping("/tipo/{tipoEvento}")
    public ResponseEntity<List<EventosModel>> porTipo(@PathVariable("tipoEvento") String tipo) {
        return ResponseEntity.ok(svc.buscarPorTipoEvento(tipo));
    }

    // BUSCAR POR UBICACIÓN
    @GetMapping("/ubicacion/{ubicacion}")
    public ResponseEntity<List<EventosModel>> porUbicacion(@PathVariable("ubicacion") String ub) {
        return ResponseEntity.ok(svc.buscarPorUbicacion(ub));
    }

    // ACTUALIZAR
    @PutMapping("/{nombre}")
    public ResponseEntity<EventosModel> actualizar(@PathVariable String nombre, @Valid @RequestBody EventosModel r) {
        return ResponseEntity.ok(svc.actualizar(nombre, r));
    }

    // ELIMINAR
    @DeleteMapping("/{nombre}")
    public ResponseEntity<Void> eliminar(@PathVariable String nombre) {
        svc.eliminar(nombre);
        return ResponseEntity.noContent().build(); // Retorna 204 No Content

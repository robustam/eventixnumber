package com.eventos.eventix.repository;

import com.eventos.eventix.model.EventosModel;
import org.springframework.stereotype.Repository;

import java.util.ArrayList;
import java.util.List;
import java.util.stream.Collectors;



@Repository
public class EventosRepository {
    private List<EventosModel> registros = new ArrayList<>();

    //REGISTRAR
    public EventosModel guardar(EventosModel registro) {
        registros.add(registro);
        return registro;
    }

    // LISTAR
    public List<EventosModel> listarTodos(){
        return registros;
    }

    //BUSCAR POR NOMBRE
    public EventosModel buscarPorNombre (String nombre){
        return registros.stream()
                .filter(r->r.getNombre().equalsIgnoreCase(nombre))
                .findFirst()
                .orElse(null);
    }

    //BUSCAR POR TIPOS DE EVENTOS
    public List<EventosModel> buscarPorTipoEvento(String tipo) {
        return registros.stream()
        .filter(r -> r.getTipoevento().equalsIgnoreCase(tipo))
        .collect(Collectors.toList());
    }

    //BUSCAR POR UBICACION
    public List<EventosModel> buscarPorUbicacion(String ubicacion){
    return registros.stream()
            .filter(r-> r.getUbicacion().equalsIgnoreCase(ubicacion))
            .collect(Collectors.toList());
}

// ACTUALIZAR
public EventosModel actualizar(String nombre, EventosModel act){
    for (int i=0; i<registros.size();i++){
        if(registros.get(i).getNombre().equalsIgnoreCase(nombre)) {
            registros.set(i, act);
            return act;
        }
    }
    return null;
}
public boolean eliminar(String nombre)
{
    return registros.removeIf(r-> r.getNombre().equalsIgnoreCase(nombre));
}
}


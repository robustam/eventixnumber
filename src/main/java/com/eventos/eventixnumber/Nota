package com.eventos.eventix.service;

import com.eventos.eventix.exception.EventoNotFoundException;
import com.eventos.eventix.model.EventosModel;
import com.eventos.eventix.repository.EventosRepository;
import org.springframework.stereotype.Service;
import java.util.List;

@Service
public class EventosServiceImpl implements EventosService {

    private final EventosRepository repo;

    public EventosServiceImpl(EventosRepository repo) {
        this.repo = repo;
    }

    // REGISTRAR
    @Override
    public EventosModel guardar(EventosModel registro) {
        if (repo.buscarPorNombre(registro.getNombre()) != null) {
            throw new IllegalArgumentException("Ya existe el evento: " + registro.getNombre());
        }
        return repo.guardar(registro);
    }

    // LISTAR
    @Override
    public List<EventosModel> listarTodos() {
        return repo.listarTodos();
    }

    // BUSCAR POR NOMBRE
    @Override
    public EventosModel buscarPorNombre(String nombre) {
        EventosModel r = repo.buscarPorNombre(nombre);
        if (r == null) {
            throw new EventoNotFoundException("Evento no encontrado: " + nombre);
        }
        return r;
    }

    // BUSCAR POR TIPO EVENTO
    @Override
    public List<EventosModel> buscarPorTipoEvento(String t) {
        return repo.buscarPorTipoEvento(t);
    }

    // BUSCAR POR UBICACION
    @Override
    public List<EventosModel> buscarPorUbicacion(String u) {
        return repo.buscarPorUbicacion(u);
    }

    // ACTUALIZAR
    @Override
    public EventosModel actualizar(String nombre, EventosModel act) {
        if (repo.buscarPorNombre(nombre) == null) {
            throw new EventoNotFoundException("No existe el evento: " + nombre);
        }
        return repo.actualizar(nombre, act);
    }

    // ELIMINAR
    @Override
    public boolean eliminar(String nombre) {
        if (repo.buscarPorNombre(nombre) == null) {
            throw new EventoNotFoundException("Evento no encontrado: " + nombre);
        }
        return repo.eliminar(nombre);
    }
}

